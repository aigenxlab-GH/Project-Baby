{
  "name": "project-baby",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run search-index && next build",
    "start": "next start",
    "lint": "next lint",
    "generate": "tsx scripts/generate-content.ts",
    "generate:batch": "tsx scripts/generate-content.ts --batch",
    "generate:mega": "tsx scripts/generate-content.ts --mega",
    "search-index": "tsx scripts/build-search-index.ts",
    "pages:build": "npm run build && npx @cloudflare/next-on-pages",
    "pages:preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name=pregnancysprout"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.4.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time": "^1.5.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/typography": "^0.5.15",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "wrangler": "^4.98.0"
  }
}
