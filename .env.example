# ─────────────────────────────────────────────────────────────────────────────
# PregnancySprout — Environment Variables
# Copy this file to .env.local for local development.
# Set all variables in Vercel dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── CRITICAL: Site URL ────────────────────────────────────────────────────────
# Exact URL. NO trailing slash. Always https:// in production.
# Controls: canonical tags, sitemap.xml, JSON-LD schemas, OG tags.
# Wrong value = broken canonicals = SEO damage on every page.
#
# Local:      NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://pregnancysprout.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google AdSense ────────────────────────────────────────────────────────────
# Get from: https://adsense.google.com → Account → Publisher ID
# Format:  ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ── Email Newsletter ──────────────────────────────────────────────────────────
# ConvertKit (preferred):
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Mailchimp (used only if ConvertKit keys are empty):
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=us1

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL PRODUCTION CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
# 1. NEXT_PUBLIC_SITE_URL=https://pregnancysprout.com   (exact, no slash)
# 2. NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXX
# 3. CONVERTKIT_API_KEY + CONVERTKIT_FORM_ID
# 4. After deploy: open https://pregnancysprout.com/robots.txt → confirm /_next/ NOT blocked
# 5. After deploy: open https://pregnancysprout.com/sitemap.xml → verify 1400+ URLs
# 6. Google Search Console → Sitemaps → submit https://pregnancysprout.com/sitemap.xml
# ─────────────────────────────────────────────────────────────────────────────
