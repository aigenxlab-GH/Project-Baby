# ─────────────────────────────────────────────────────────────────────────────
# PregnancySprout — Environment Variables
# Copy to .env.local for local development.
# Set ALL variables in Cloudflare Pages dashboard for production.
# Dashboard: Cloudflare → Pages → pregnancysprout → Settings → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# ── CRITICAL: Site URL ────────────────────────────────────────────────────────
# Exact production URL. NO trailing slash. Always https:// in production.
# Controls: canonical tags, sitemap.xml, JSON-LD schemas, Open Graph tags.
# Wrong value = broken canonicals across every page = SEO damage.
#
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Production (Cloudflare Pages dashboard → both "Production" and "Preview"):
# NEXT_PUBLIC_SITE_URL=https://pregnancysprout.com

# ── Google AdSense ────────────────────────────────────────────────────────────
# Get from: https://adsense.google.com → Account → Publisher ID
# Format:   ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ── Email Newsletter ──────────────────────────────────────────────────────────
# ConvertKit (preferred):
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Mailchimp (used only if ConvertKit keys are not set):
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=us1

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE PAGES — DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. CONNECT REPO
#    Cloudflare Pages dashboard → Create application → Connect to Git
#    Select your GitHub/GitLab repo
#
# 2. BUILD SETTINGS (in Cloudflare Pages dashboard)
#    Framework preset:    Next.js
#    Build command:       npm run pages:build
#    Build output dir:    .vercel/output/static
#    Root directory:      /   (leave empty)
#    Node.js version:     20.x  (set in Environment variables as NODE_VERSION=20)
#
# 3. ENVIRONMENT VARIABLES (Cloudflare Pages → Settings → Environment variables)
#    Add for BOTH Production AND Preview environments:
#      NEXT_PUBLIC_SITE_URL         = https://pregnancysprout.com
#      NEXT_PUBLIC_ADSENSE_PUBLISHER_ID = ca-pub-XXXXXXXXXXXXXXXXX
#      CONVERTKIT_API_KEY           = (your key)
#      CONVERTKIT_FORM_ID           = (your form ID)
#      NODE_VERSION                 = 20
#
# 4. CUSTOM DOMAIN
#    Cloudflare Pages → Custom domains → Add domain
#    Add: pregnancysprout.com
#    (If domain is on Cloudflare DNS, it configures automatically)
#
# 5. AFTER FIRST DEPLOY — VERIFY
#    ✓ https://pregnancysprout.com/robots.txt   → /_next/ must NOT be in Disallow
#    ✓ https://pregnancysprout.com/sitemap.xml  → should list 1,400+ URLs
#    ✓ https://pregnancysprout.com/api/search?q=pregnancy → returns results
#    ✓ Newsletter form → submits without 500 error
#
# 6. GOOGLE SEARCH CONSOLE
#    Add property: https://pregnancysprout.com
#    Verify via DNS TXT record (Cloudflare DNS → add TXT record)
#    Sitemaps → Submit → https://pregnancysprout.com/sitemap.xml
#
# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE PAGES SPECIFIC NOTES
# ─────────────────────────────────────────────────────────────────────────────
#
# wrangler.toml:
#   compatibility_flags = ["nodejs_compat"]
#   This enables Node.js built-ins (fs, path, crypto) in Cloudflare Workers.
#   Required for: MDX content reading, product catalog, sitemap generation.
#
# Image Optimization:
#   next.config.mjs has images.unoptimized = true
#   Cloudflare Workers don't support `sharp`. All images are from Unsplash CDN
#   which already serves optimised images via URL parameters (?w=800&q=85).
#   Cloudflare's own CDN also caches/serves images efficiently.
#
# Rate Limiting (/api/newsletter):
#   In-memory rate limit (Map) works per Cloudflare Worker instance.
#   For global rate limiting, upgrade to Cloudflare KV or Durable Objects.
#
# ─────────────────────────────────────────────────────────────────────────────
